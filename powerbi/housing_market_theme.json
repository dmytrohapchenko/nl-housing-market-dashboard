{
  "name": "Housing Market Light",
  "dataColors": [
    "#1F4E79",
    "#2A9D8F",
    "#6C757D",
    "#A7C7E7",
    "#8AB17D",
    "#B8B8B8"
  ],
  "background": "#F4F6F8",
  "foreground": "#2F3A45",
  "tableAccent": "#1F4E79",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F4F6F8"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D9DEE5"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#2F3A45"
              }
            },
            "fontSize": 11
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#4F5B66"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#4F5B66"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#4F5B66"
              }
            },
            "gridlineColor": {
              "solid": {
                "color": "#E6EAF0"
              }
            }
          }
        ]
      }
    },
    "card": {
      "*": {
        "calloutValue": [
          {
            "color": {
              "solid": {
                "color": "#1F4E79"
              }
            },
            "fontSize": 26
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#4F5B66"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}
